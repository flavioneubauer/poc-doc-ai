# Copie para `litellm.env` e preencha. NÃO commitar (está no .gitignore).
# Os valores OCI_* saem do seu ~/.oci/config [genai] (assinatura Signature v1).
OCI_REGION=sa-saopaulo-1
OCI_USER=ocid1.user.oc1..xxxx
OCI_FINGERPRINT=aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99
OCI_TENANCY=ocid1.tenancy.oc1..xxxx
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxx
# Caminho DENTRO do container (a .pem é montada em /keys/oci.pem pelo compose).
OCI_KEY_FILE=/keys/oci.pem
# Master key do gateway — o proxy Node usa como bearer (LITELLM_MASTER_KEY no server/.env).
LITELLM_MASTER_KEY=sk-litellm-CHANGE-ME

# OpenAI roteada pelo gateway (opcional; modelo lite-gpt-4o-mini no config.yaml).
OPENAI_API_KEY=sk-proj-...

# --- UI admin (http://localhost:4000/ui) ---
UI_USERNAME=admin
UI_PASSWORD=troque-esta-senha
# Banco (serviço `db` do compose); a UI precisa dele.
DATABASE_URL=postgresql://litellm:litellm@db:5432/litellm
STORE_MODEL_IN_DB=True
