# Copie para `.env` e preencha. NÃO commitar o `.env`.

# --- Provedor do LLM ---
# 'openai' (padrão) ou 'oci'. Nos dois casos usamos a lib `openai`; a OCI só
# muda a base_url, a chave e o header de compartment.
LLM_PROVIDER=openai

# --- OpenAI (quando LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# --- OCI Generative AI, modo compatível com OpenAI (quando LLM_PROVIDER=oci) ---
# A chave é a "API Key" bearer da OCI (Generative AI -> API Keys), NÃO a de
# assinatura do ~/.oci/config. O compartment vai no header opc-compartment-id.
OCI_GENAI_API_KEY=sk-...
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxx
OCI_REGION=sa-saopaulo-1
OCI_MODELS=meta.llama-3.3-70b-instruct,meta.llama-3.2-90b-vision-instruct

# --- LiteLLM Gateway (container local — OPCIONAL) ---
# OpenAI-compatible; via OCI nativo (assinatura .pem) alcança Cohere/embeddings,
# que o endpoint compat da OCI não entrega. Sobe com docker compose (ver litellm/).
# Só entra no combo se BASE_URL + MASTER_KEY estiverem preenchidos.
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_MASTER_KEY=sk-litellm-CHANGE-ME
LITELLM_MODELS=oci-llama-3.3-70b,oci-llama-3.2-90b-vision,oci-cohere-command,lite-gpt-4o-mini

# --- CleanPredict (guardrail/observabilidade — OPCIONAL) ---
# Só liga se AS DUAS estiverem preenchidas. Sem elas, o proxy vai direto ao LLM
# (util para testar os modelos da OCI sem o guardrail no caminho).
CLEANPREDICT_API_KEY=
CLEANPREDICT_BASE_URL=https://api.cleanpredict.com/api/v1
# workspace_slug (ex.: meu_workspace). A doc também aceita workspace_id (UUID);
# se preferir o UUID, troque o nome da variável e ajuste index.js.
CLEANPREDICT_WORKSPACE_SLUG=

# --- Servidor local ---
# Backend interno; o ng serve (porta 17000) faz proxy de /api para cá.
PORT=13001
ALLOWED_ORIGIN=http://localhost:17000
